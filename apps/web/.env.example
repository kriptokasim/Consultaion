NEXT_PUBLIC_ENABLE_POSTHOG=0
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# DiceBear Avatars
NEXT_PUBLIC_ENABLE_DICEBEAR_AVATARS=1
NEXT_PUBLIC_DICEBEAR_STYLE=identicon

# Feature Flags - Master Patchset
STAGED_DECISION_PIPELINE=0
NEXT_PUBLIC_STAGED_DECISION_PIPELINE=0
NEXT_PUBLIC_UNIFIED_WORKSPACE=0
NEXT_PUBLIC_MOBILE_WORKSPACE_V2=0
NEXT_PUBLIC_JIT_AUTH=0
NEXT_PUBLIC_MOBILE_REPORT_V2=0

# Feature Flags - Operational Trust
ENABLE_LLM_OPERATION_LIMITS=0
ENABLE_PROMETHEUS_METRICS=0
ENABLE_OTEL_TRACING=0
ENABLE_GDPR_SELF_SERVICE=0
NEXT_PUBLIC_STATUS_PAGE=0
NEXT_PUBLIC_CHANGELOG=0
NEXT_PUBLIC_OFFLINE_RECOVERY=0

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

# Internal Security
INTERNAL_SECRET=CHANGE_ME_IN_PRODUCTION
# CRITICAL: Must be exactly the same string in both frontend and backend
# MUST be 32+ characters in production

